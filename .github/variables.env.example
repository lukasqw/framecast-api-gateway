# =============================================================================
# Repository Variables — Settings → Secrets and Variables → Variables
# Copy this file, fill in the values and configure in the GitHub UI.
# =============================================================================

# --- AWS -------------------------------------------------------------------
AWS_REGION=us-east-1

# --- Terraform -------------------------------------------------------------
TF_VERSION=1.7.0
# For api-gateway the Terraform root is the repo root (default: .)
TF_WORKING_DIR=.

# --- Node.js ---------------------------------------------------------------
NODE_VERSION=20

# --- Health Check ----------------------------------------------------------
HEALTH_ENDPOINT=/health

# --- Release Flow ----------------------------------------------------------
# Branches used by release.yml to create / update the release PR.
# Defaults to 'main' and 'develop' if not set.
BASE_BRANCH=main
SOURCE_BRANCH=develop

# =============================================================================
# Secrets — Settings → Secrets and Variables → Secrets
# =============================================================================

# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=      (for temporary credentials / IAM role assumption)
# JWT_SECRET_KEY=         (TF_VAR_jwt_secret — API Gateway JWT signing secret)
# DB_PASSWORD=            (TF_VAR_db_password — RDS master password)
