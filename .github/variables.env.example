# =============================================================================
# Repository Variables — Settings → Secrets and Variables → Variables
# Copy this file, fill in the values and configure in the GitHub UI.
# =============================================================================

# --- AWS -------------------------------------------------------------------
AWS_REGION=us-east-1

# --- Terraform -------------------------------------------------------------
TF_VERSION=1.7.0
TF_WORKING_DIR=terraform/environments/production
TF_STATE_BUCKET=fiap-soat-tf-backend-framecast

# --- Health Check ----------------------------------------------------------
HEALTH_ENDPOINT=/health

# --- Release Flow ----------------------------------------------------------
BASE_BRANCH=main
SOURCE_BRANCH=develop

# =============================================================================
# Secrets — Settings → Secrets and Variables → Secrets
# =============================================================================

# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=      (for temporary credentials / IAM role assumption)
