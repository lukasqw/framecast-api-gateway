# ============================================================================
# framecast-gateway — Terraform Variables Example
# ============================================================================
# cp terraform.tfvars.example terraform.tfvars
# O arquivo terraform.tfvars é gitignored — não commitar.
# ============================================================================

# ----------------------------------------------------------------------------
# Básico
# ----------------------------------------------------------------------------

environment = "production"
stage_name  = "v1"
aws_region  = "us-east-1"

# Bucket S3 do Terraform state (deve coincidir com o -backend-config do init)
tf_state_bucket = "fiap-soat-tf-backend-framecast"

# ----------------------------------------------------------------------------
# Backend — framecast-api
# ----------------------------------------------------------------------------

# Deixe vazio para derivar automaticamente do NLB DNS via remote state da infra.
# Preencha apenas se quiser sobrescrever (ex: teste local com ngrok).
# framecast_api_endpoint = "http://meu-nlb.elb.us-east-1.amazonaws.com:30080"

# NodePort da framecast-api exposto no NLB (padrão: 30080)
nodeport = 30080

# ----------------------------------------------------------------------------
# VPC Link
# ----------------------------------------------------------------------------

# true  → connectionType=VPC_LINK (produção, requer NLB ARN no remote state)
# false → connectionType=INTERNET (dev / LocalStack)
enable_vpc_link = true

# ----------------------------------------------------------------------------
# WAF
# ----------------------------------------------------------------------------

# true  → WAFv2 WebACL associado ao stage (requer permissão wafv2:* na role)
# false → sem WAF (use em AWS Academy / LabRole sem wafv2:*)
enable_waf = true

# Limite de requisições por IP em 5 minutos antes de bloquear
waf_rate_limit = 2000

# ----------------------------------------------------------------------------
# Throttling e Quota
# ----------------------------------------------------------------------------

throttle_burst_limit = 5000
throttle_rate_limit  = 10000
quota_limit          = 1000000

# ----------------------------------------------------------------------------
# Logging e Alarmes
# ----------------------------------------------------------------------------

enable_logging     = true
log_retention_days = 7
enable_alarms      = true

error_threshold_5xx  = 10
error_threshold_4xx  = 100
latency_threshold_ms = 5000

# ----------------------------------------------------------------------------
# Cache (desabilitado por padrão — habilitar aumenta custo)
# ----------------------------------------------------------------------------

enable_cache        = false
cache_cluster_size  = "0.5"
cache_ttl_seconds   = 300

# ----------------------------------------------------------------------------
# API Key (opcional — camada extra de controle)
# ----------------------------------------------------------------------------

enable_api_key = false

# ----------------------------------------------------------------------------
# Custom Domain (opcional)
# ----------------------------------------------------------------------------

# custom_domain_name = "api.framecast.com"
# certificate_arn    = "arn:aws:acm:us-east-1:123456789:certificate/xxx"

# ----------------------------------------------------------------------------
# AWS Academy / LabRole (opcional — auto-detectado se vazio)
# ----------------------------------------------------------------------------

# lab_role = "arn:aws:iam::123456789:role/LabRole"

# ============================================================================
# Exemplos por ambiente
# ============================================================================

# --- DEV (LocalStack / sem VPC Link) ---
# enable_vpc_link = false
# enable_waf      = false
# enable_logging  = false
# enable_alarms   = false

# --- PRODUÇÃO ---
# enable_vpc_link      = true
# enable_waf           = true
# enable_logging       = true
# enable_alarms        = true
# error_threshold_5xx  = 5
# latency_threshold_ms = 3000
