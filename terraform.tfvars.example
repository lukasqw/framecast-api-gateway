# AWS Configuration
aws_region  = "us-east-1"
environment = "production"
stage_name  = "v1"

# Backend Configuration
alb_endpoint = "https://your-alb-endpoint.us-east-1.elb.amazonaws.com"

# Security
jwt_secret = "your-jwt-secret-key-must-be-32-characters-or-more"

# Database Configuration
# Note: db_host, db_port, db_user, db_name are automatically read from remote state
# Only db_password needs to be provided (must match the backend infrastructure)
db_password = "your-secure-database-password"
db_ssl_enabled = "true"

# AWS Academy IAM Configuration (optional - auto-constructed if not provided)
# lab_role      = "arn:aws:iam::123456789012:role/LabRole"
# principal_arn = "arn:aws:iam::123456789012:role/voclabs"

# VPC Configuration for Lambda
# Note: lambda_subnet_ids and lambda_security_group_ids are automatically read from remote state
# Uncomment below only if you need to override the remote state values
# lambda_subnet_ids         = ["subnet-xxxxx", "subnet-yyyyy"]
# lambda_security_group_ids = ["sg-xxxxx"]

# CORS Configuration
allowed_origins = [
  "https://yourdomain.com",
  "https://www.yourdomain.com"
]

# Logging
log_retention_days = 30

# Throttling
throttle_burst_limit = 5000
throttle_rate_limit  = 10000

# Optional Features
enable_waf     = false
enable_api_key = false
