{
  "openapi": "3.0.0",
  "info": {
    "title": "Framecast API",
    "description": "Pipeline distribuído de extração de frames de vídeo. Gateway proxy + WAF — auth delegada à framecast-api (JWT HS256).",
    "version": "1.0",
    "contact": {
      "name": "Framecast",
      "email": "support@framecast.io"
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "apiKey",
        "name": "Authorization",
        "in": "header",
        "description": "JWT obtido via POST /api/auth/login. Formato: Bearer {token}"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "example": "UNAUTHORIZED"
              },
              "message": {
                "type": "string",
                "example": "invalid or expired token"
              }
            }
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "minLength": 8,
            "example": "password123"
          }
        }
      },
      "RegisterRequest": {
        "type": "object",
        "required": ["name", "email", "password"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 2,
            "example": "João Silva"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "minLength": 8,
            "example": "password123"
          }
        }
      }
    },
    "parameters": {
      "AuthorizationHeader": {
        "name": "Authorization",
        "in": "header",
        "required": true,
        "schema": {
          "type": "string",
          "pattern": "^Bearer .+"
        },
        "description": "JWT no formato: Bearer {token}"
      },
      "VideoIdPath": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        },
        "description": "UUID do vídeo"
      }
    }
  },
  "x-amazon-apigateway-request-validators": {
    "all": {
      "validateRequestBody": true,
      "validateRequestParameters": true
    },
    "params-only": {
      "validateRequestBody": false,
      "validateRequestParameters": true
    },
    "body-only": {
      "validateRequestBody": true,
      "validateRequestParameters": false
    }
  },
  "x-amazon-apigateway-request-validator": "all",
  "x-amazon-apigateway-gateway-responses": {
    "DEFAULT_4XX": {
      "responseParameters": {
        "gatewayresponse.header.Access-Control-Allow-Origin": "'*'",
        "gatewayresponse.header.Access-Control-Allow-Headers": "'Content-Type,Authorization,X-Amz-Date,X-Api-Key,X-Amz-Security-Token'"
      },
      "responseTemplates": {
        "application/json": "{\"error\":{\"code\":\"CLIENT_ERROR\",\"message\":\"$context.error.messageString\"}}"
      }
    },
    "DEFAULT_5XX": {
      "responseParameters": {
        "gatewayresponse.header.Access-Control-Allow-Origin": "'*'",
        "gatewayresponse.header.Access-Control-Allow-Headers": "'Content-Type,Authorization,X-Amz-Date,X-Api-Key,X-Amz-Security-Token'"
      },
      "responseTemplates": {
        "application/json": "{\"error\":{\"code\":\"SERVER_ERROR\",\"message\":\"internal server error\"}}"
      }
    },
    "UNAUTHORIZED": {
      "statusCode": 401,
      "responseParameters": {
        "gatewayresponse.header.Access-Control-Allow-Origin": "'*'"
      },
      "responseTemplates": {
        "application/json": "{\"error\":{\"code\":\"UNAUTHORIZED\",\"message\":\"missing or invalid Authorization header\"}}"
      }
    },
    "ACCESS_DENIED": {
      "statusCode": 403,
      "responseParameters": {
        "gatewayresponse.header.Access-Control-Allow-Origin": "'*'"
      },
      "responseTemplates": {
        "application/json": "{\"error\":{\"code\":\"FORBIDDEN\",\"message\":\"access denied\"}}"
      }
    },
    "THROTTLED": {
      "statusCode": 429,
      "responseParameters": {
        "gatewayresponse.header.Access-Control-Allow-Origin": "'*'",
        "gatewayresponse.header.Retry-After": "'60'"
      },
      "responseTemplates": {
        "application/json": "{\"error\":{\"code\":\"RATE_LIMIT_EXCEEDED\",\"message\":\"too many requests\"}}"
      }
    },
    "REQUEST_TOO_LARGE": {
      "statusCode": 413,
      "responseParameters": {
        "gatewayresponse.header.Access-Control-Allow-Origin": "'*'"
      },
      "responseTemplates": {
        "application/json": "{\"error\":{\"code\":\"PAYLOAD_TOO_LARGE\",\"message\":\"request payload too large (max 10 MB)\"}}"
      }
    }
  }
}
