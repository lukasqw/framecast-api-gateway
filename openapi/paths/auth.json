{
  "/api/auth/register": {
    "post": {
      "summary": "Cadastro de usuário",
      "tags": ["auth"],
      "x-amazon-apigateway-request-validator": "body-only",
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/RegisterRequest" }
          }
        }
      },
      "responses": {
        "201": { "description": "Usuário criado" },
        "409": { "description": "Email já cadastrado" },
        "422": { "description": "Dados inválidos" }
      },
      "x-amazon-apigateway-integration": {
        "type": "http_proxy",
        "httpMethod": "POST",
        "uri": "http://${framecast_api_endpoint}/api/auth/register",
        "connectionType": "${connection_type}",
        "connectionId": "${vpc_link_id}",
        "passthroughBehavior": "when_no_match",
        "timeoutInMillis": 29000
      }
    }
  },
  "/api/auth/login": {
    "post": {
      "summary": "Login — retorna JWT",
      "tags": ["auth"],
      "x-amazon-apigateway-request-validator": "body-only",
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/LoginRequest" }
          }
        }
      },
      "responses": {
        "200": { "description": "Login bem-sucedido" },
        "401": { "description": "Credenciais inválidas" }
      },
      "x-amazon-apigateway-integration": {
        "type": "http_proxy",
        "httpMethod": "POST",
        "uri": "http://${framecast_api_endpoint}/api/auth/login",
        "connectionType": "${connection_type}",
        "connectionId": "${vpc_link_id}",
        "passthroughBehavior": "when_no_match",
        "timeoutInMillis": 29000
      }
    }
  },
  "/api/auth/logout": {
    "post": {
      "summary": "Logout — invalida tokens via token_invalidated_at",
      "tags": ["auth"],
      "security": [{ "BearerAuth": [] }],
      "x-amazon-apigateway-request-validator": "params-only",
      "parameters": [
        { "$ref": "#/components/parameters/AuthorizationHeader" }
      ],
      "responses": {
        "204": { "description": "Logout realizado" },
        "401": { "description": "Token inválido" }
      },
      "x-amazon-apigateway-integration": {
        "type": "http_proxy",
        "httpMethod": "POST",
        "uri": "http://${framecast_api_endpoint}/api/auth/logout",
        "connectionType": "${connection_type}",
        "connectionId": "${vpc_link_id}",
        "passthroughBehavior": "when_no_match",
        "timeoutInMillis": 29000
      }
    }
  }
}
