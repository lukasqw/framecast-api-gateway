  "/service-orders/{id}/retry-payment": {
    "post": {
      "summary": "Retry payment after rejection",
      "description": "Creates a new Mercado Pago Order for a service order in PAYMENT_REJECTED status. Returns the OS to AWAITING_PAYMENT with a new payment_url.",
      "tags": ["service-orders"],
      "security": [{ "BearerAuth": [] }],
      "parameters": [
        { "name": "Authorization", "in": "header", "required": false, "schema": { "type": "string" }, "description": "Bearer token" },
        { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "responses": {
        "202": { "description": "Accepted — new MP Order created, OS back to AWAITING_PAYMENT" },
        "400": { "description": "Bad Request — OS not in PAYMENT_REJECTED" },
        "401": { "description": "Unauthorized" },
        "404": { "description": "Not Found" },
