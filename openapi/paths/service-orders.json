  "/service-orders": {
    "get": {
      "summary": "List all service orders",
      "description": "Retrieves all service orders with optional filtering by customer ID and status",
      "tags": ["service-orders"],
      "security": [{ "BearerAuth": [] }],
      "parameters": [
        { "name": "Authorization", "in": "header", "required": false, "schema": { "type": "string" }, "description": "Bearer token" },
        { "name": "customer_id", "in": "query", "required": false, "schema": { "type": "string" } },
        { "name": "status", "in": "query", "required": false, "schema": { "type": "string" } }
      ],
      "responses": {
        "200": { "description": "Success" },
        "401": { "description": "Unauthorized" },
        "500": { "description": "Internal Server Error" }
      },
      "x-amazon-apigateway-integration": {
        "type": "http_proxy",
        "httpMethod": "GET",
        "uri": "${ms_order_endpoint}/service-orders",
        "connectionType": "INTERNET",
        "passthroughBehavior": "when_no_match",
        "timeoutInMillis": 29000,
        "requestParameters": {
          "integration.request.header.X-User-Id": "context.authorizer.userId",
          "integration.request.header.X-User-Role": "context.authorizer.role",
          "integration.request.header.X-User-Email": "context.authorizer.email"
        },
        "responses": { "default": { "statusCode": "200" } }
      }
    },
    "post": {
      "summary": "Create a new service order",
      "description": "Creates a new service order with items (products and/or services) for a customer's vehicle. Status inicial: RECEIVED.",
      "tags": ["service-orders"],
      "security": [{ "BearerAuth": [] }],
      "parameters": [
        { "name": "Authorization", "in": "header", "required": false, "schema": { "type": "string" }, "description": "Bearer token" }
      ],
      "responses": {
        "200": { "description": "Success" },
        "400": { "description": "Bad Request" },
        "401": { "description": "Unauthorized" },
        "500": { "description": "Internal Server Error" }
