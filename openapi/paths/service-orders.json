  "/payments/result": {
    "get": {
      "summary": "Payment result redirect page",
      "description": "Public endpoint — destination for Mercado Pago redirect after checkout (success/pending/failure). Renders a static HTML page. Does NOT require user JWT.",
      "tags": ["payments"],
      "parameters": [
        { "name": "status", "in": "query", "required": true, "schema": { "type": "string", "enum": ["success", "pending", "failure"] } },
        { "name": "order", "in": "query", "required": false, "schema": { "type": "string" }, "description": "Service order ID" }
      ],
      "responses": {
        "200": { "description": "HTML result page" },
        "400": { "description": "Invalid status parameter" }
      },
      "x-amazon-apigateway-integration": {
        "type": "http_proxy",
        "httpMethod": "GET",
        "uri": "${ms_order_endpoint}/payments/result",
        "connectionType": "INTERNET",
        "passthroughBehavior": "when_no_match",
        "timeoutInMillis": 29000,
        "responses": { "default": { "statusCode": "200" } }
      }
    }
  },
  "/payments/mp-webhook": {
    "post": {
      "summary": "Mercado Pago webhook",
      "description": "Receives payment status notifications from Mercado Pago. Called by Mercado Pago servers — does NOT require user JWT. Signature validated internally via x-signature header + MP_WEBHOOK_SECRET.",
      "tags": ["payments"],
      "parameters": [
        { "name": "x-signature",  "in": "header", "required": false, "schema": { "type": "string" } },
        { "name": "x-request-id", "in": "header", "required": false, "schema": { "type": "string" } },
        { "name": "data.id",      "in": "query",  "required": false, "schema": { "type": "string" } }
      ],
      "responses": {
        "200": { "description": "Webhook processed" },
        "400": { "description": "Invalid signature or payload" },
        "401": { "description": "Invalid or missing webhook signature" },
        "500": { "description": "Internal Server Error" }
      },
      "x-amazon-apigateway-integration": {
        "type": "http_proxy",
        "httpMethod": "POST",
        "uri": "${ms_order_endpoint}/payments/mp-webhook",
        "connectionType": "INTERNET",
        "passthroughBehavior": "when_no_match",
        "timeoutInMillis": 29000,
        "requestParameters": {
          "integration.request.header.x-signature":  "method.request.header.x-signature",
          "integration.request.header.x-request-id": "method.request.header.x-request-id"
        },
        "responses": { "default": { "statusCode": "200" } }
      }
    }
  }
