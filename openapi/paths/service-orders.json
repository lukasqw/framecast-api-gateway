  "/service-orders/{id}/advance": {
    "post": {
      "summary": "Advance service order status",
      "description": "Advances the service order to the next status. Transitions that involve stock operations return 202 Accepted (async saga). Sequence: RECEIVED → DIAGNOSING → PENDING_AUTHORIZATION → AUTHORIZED → IN_PROGRESS → COMPLETED → AWAITING_PAYMENT → PAID → DELIVERED.",
      "tags": ["service-orders"],
      "security": [{ "BearerAuth": [] }],
      "parameters": [
        { "name": "Authorization", "in": "header", "required": false, "schema": { "type": "string" }, "description": "Bearer token" },
        { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "responses": {
        "200": { "description": "Status advanced (synchronous transition)" },
        "202": { "description": "Accepted — saga step initiated (async stock operation)" },
        "400": { "description": "Bad Request — invalid transition" },
        "401": { "description": "Unauthorized" },
        "404": { "description": "Not Found" },
        "500": { "description": "Internal Server Error" }
      },
      "x-amazon-apigateway-integration": {
        "type": "http_proxy",
        "httpMethod": "POST",
        "uri": "${ms_order_endpoint}/service-orders/{id}/advance",
        "connectionType": "INTERNET",
        "passthroughBehavior": "when_no_match",
        "timeoutInMillis": 29000,
        "requestParameters": {
          "integration.request.path.id": "method.request.path.id",
          "integration.request.header.X-User-Id": "context.authorizer.userId",
          "integration.request.header.X-User-Role": "context.authorizer.role",
          "integration.request.header.X-User-Email": "context.authorizer.email"
        },
        "responses": { "default": { "statusCode": "200" } }
      }
    }
  },
  "/service-orders/{id}/authorize": {
    "post": {
      "summary": "Authorize or reject service order",
      "description": "Customer approves or rejects the service order in PENDING_AUTHORIZATION status. Rejection triggers CANCEL_RESERVED saga step.",
      "tags": ["service-orders"],
      "security": [{ "BearerAuth": [] }],
      "parameters": [
        { "name": "Authorization", "in": "header", "required": false, "schema": { "type": "string" }, "description": "Bearer token" },
        { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "responses": {
        "200": { "description": "Success" },
        "400": { "description": "Bad Request — OS not in PENDING_AUTHORIZATION" },
        "401": { "description": "Unauthorized" },
        "404": { "description": "Not Found" },
        "500": { "description": "Internal Server Error" }
      },
      "x-amazon-apigateway-integration": {
        "type": "http_proxy",
        "httpMethod": "POST",
        "uri": "${ms_order_endpoint}/service-orders/{id}/authorize",
        "connectionType": "INTERNET",
        "passthroughBehavior": "when_no_match",
        "timeoutInMillis": 29000,
        "requestParameters": {
          "integration.request.path.id": "method.request.path.id",
