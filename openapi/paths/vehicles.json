{
  "/vehicles": {
    "get": {
      "summary": "List all vehicles",
      "description": "Retrieve a list of all vehicles with optional filtering by customer ID",
      "tags": ["vehicles"],
      "responses": {
        "200": { "description": "Success" },
        "400": { "description": "Bad Request" },
        "401": { "description": "Unauthorized" },
        "404": { "description": "Not Found" },
        "500": { "description": "Internal Server Error" }
      },
      "security": [{ "BearerAuth": [] }],
      "parameters": [
        {
          "name": "customer_id",
          "in": "query",
          "required": false,
          "schema": { "type": "string" }
        }
      ],
      "x-amazon-apigateway-integration": {
        "type": "http_proxy",
        "httpMethod": "GET",
        "uri": "${alb_endpoint}/vehicles",
        "passthroughBehavior": "when_no_match",
        "requestParameters": {
          "integration.request.header.Authorization": "method.request.header.Authorization"
        }
      }
    },
    "post": {
      "summary": "Create a new vehicle",
      "description": "Register a new vehicle in the system with license plate and customer ownership",
      "tags": ["vehicles"],
      "responses": {
        "200": { "description": "Success" },
        "400": { "description": "Bad Request" },
        "401": { "description": "Unauthorized" },
        "404": { "description": "Not Found" },
        "500": { "description": "Internal Server Error" }
      },
      "security": [{ "BearerAuth": [] }],
      "parameters": [],
      "x-amazon-apigateway-integration": {
        "type": "http_proxy",
        "httpMethod": "POST",
        "uri": "${alb_endpoint}/vehicles",
        "passthroughBehavior": "when_no_match",
        "requestParameters": {
          "integration.request.header.Authorization": "method.request.header.Authorization"
        }
      }
    }
  },
  "/vehicles/{id}": {
    "get": {
      "summary": "Get vehicle by ID",
      "description": "Retrieve detailed information about a specific vehicle including customer relationship",
      "tags": ["vehicles"],
      "responses": {
        "200": { "description": "Success" },
        "400": { "description": "Bad Request" },
        "401": { "description": "Unauthorized" },
        "404": { "description": "Not Found" },
        "500": { "description": "Internal Server Error" }
      },
      "security": [{ "BearerAuth": [] }],
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": { "type": "string" }
        }
      ],
      "x-amazon-apigateway-integration": {
        "type": "http_proxy",
        "httpMethod": "GET",
        "uri": "${alb_endpoint}/vehicles/{id}",
        "passthroughBehavior": "when_no_match",
        "requestParameters": {
          "integration.request.header.Authorization": "method.request.header.Authorization",
          "integration.request.path.id": "method.request.path.id"
        }
      }
    },
    "put": {
      "summary": "Update vehicle information",
      "description": "Update vehicle details (partial updates supported). License plate cannot be changed.",
      "tags": ["vehicles"],
      "responses": {
        "200": { "description": "Success" },
        "400": { "description": "Bad Request" },
        "401": { "description": "Unauthorized" },
        "404": { "description": "Not Found" },
        "500": { "description": "Internal Server Error" }
      },
      "security": [{ "BearerAuth": [] }],
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": { "type": "string" }
        }
      ],
      "x-amazon-apigateway-integration": {
        "type": "http_proxy",
        "httpMethod": "PUT",
        "uri": "${alb_endpoint}/vehicles/{id}",
        "passthroughBehavior": "when_no_match",
        "requestParameters": {
          "integration.request.header.Authorization": "method.request.header.Authorization",
          "integration.request.path.id": "method.request.path.id"
        }
      }
    },
    "delete": {
      "summary": "Delete a vehicle",
      "description": "Soft delete a vehicle from the system. Vehicle must not be associated with active service orders.",
      "tags": ["vehicles"],
      "responses": {
        "200": { "description": "Success" },
        "400": { "description": "Bad Request" },
        "401": { "description": "Unauthorized" },
        "404": { "description": "Not Found" },
        "500": { "description": "Internal Server Error" }
      },
      "security": [{ "BearerAuth": [] }],
      "parameters": [
        {
          "name": "id",
          "in": "path",
