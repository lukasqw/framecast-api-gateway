{
  "/": {
    "get": {
      "summary": "Raiz — redireciona para o frontend",
      "tags": ["proxy"],
      "responses": {
        "200": { "description": "Frontend HTML" }
      },
      "x-amazon-apigateway-integration": {
        "type": "http_proxy",
        "httpMethod": "GET",
        "uri": "http://${framecast_api_endpoint}/index.html",
        "connectionType": "${connection_type}",
        "connectionId": "${vpc_link_id}",
        "passthroughBehavior": "when_no_match",
        "timeoutInMillis": 29000
      }
    }
  },
  "/{proxy+}": {
    "get": {
      "summary": "Catch-all GET — frontend embed.FS (HTML, JS, CSS)",
      "tags": ["proxy"],
      "x-amazon-apigateway-request-validator": "params-only",
      "parameters": [
        {
          "name": "proxy",
          "in": "path",
          "required": true,
          "schema": { "type": "string" }
        }
      ],
      "responses": {
        "200": { "description": "Resposta do backend" }
      },
      "x-amazon-apigateway-integration": {
        "type": "http_proxy",
        "httpMethod": "GET",
        "uri": "http://${framecast_api_endpoint}/{proxy}",
        "requestParameters": {
          "integration.request.path.proxy": "method.request.path.proxy"
        },
        "connectionType": "${connection_type}",
        "connectionId": "${vpc_link_id}",
        "passthroughBehavior": "when_no_match",
        "timeoutInMillis": 29000
      }
    }
  }
}
