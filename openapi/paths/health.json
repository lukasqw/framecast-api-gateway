        "connectionType": "INTERNET",
        "passthroughBehavior": "when_no_match",
        "timeoutInMillis": 10000,
        "responses": { "default": { "statusCode": "200" } }
      }
    }
  },
  "/ms-workshop/health": {
    "get": {
      "summary": "ms-workshop health check",
