{
  "/health": {
    "get": {
      "summary": "Liveness do próprio API Gateway — mock 200, sem backend",
      "tags": ["health"],
      "x-amazon-apigateway-request-validator": "params-only",
      "responses": {
        "200": { "description": "API Gateway está respondendo" }
      },
      "x-amazon-apigateway-integration": {
        "type": "mock",
        "requestTemplates": {
          "application/json": "{\"statusCode\": 200}"
        },
        "responses": {
          "default": {
            "statusCode": "200",
            "responseTemplates": {
              "application/json": "{\"status\":\"ok\",\"service\":\"framecast-gateway\"}"
            }
          }
        }
      }
    }
  },
  "/api/health": {
    "get": {
      "summary": "Healthcheck da framecast-api (proxy)",
      "tags": ["health"],
      "x-amazon-apigateway-request-validator": "params-only",
      "responses": {
        "200": { "description": "framecast-api está respondendo" },
        "503": { "description": "framecast-api indisponível" }
      },
      "x-amazon-apigateway-integration": {
        "type": "http_proxy",
        "httpMethod": "GET",
        "uri": "http://${framecast_api_endpoint}/health",
        "connectionType": "${connection_type}",
        "connectionId": "${vpc_link_id}",
        "passthroughBehavior": "when_no_match",
        "timeoutInMillis": 10000
      }
    }
  }
}
